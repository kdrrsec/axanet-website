# Contactformulier (Formspree)
#
# Maak in Formspree een form aan en kopieer de endpoint URL.
# Voorbeeld:
#   FORMSPREE_ENDPOINT=https://formspree.io/f/abcde123
#
# Kopieer dit bestand naar .env.local en vul je echte endpoint in.

FORMSPREE_ENDPOINT=

# Publieke site-URL (canonical, sitemap, Open Graph). Op Vercel: https://www.axanet.nl
NEXT_PUBLIC_SITE_URL=

# Optioneel: Google Search Console verificatie (meta tag content-waarde)
# GOOGLE_SITE_VERIFICATION=
